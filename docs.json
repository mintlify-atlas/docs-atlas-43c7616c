{
  "$schema": "https://mintlify.com/docs.json",
  "name": "CCVim",
  "theme": "palm",
  "colors": {
    "primary": "#00AA44",
    "light": "#00CC55",
    "dark": "#007733"
  },
  "favicon": "/favicon.svg",
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/minater247/ccvim"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/minater247/ccvim"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "installation", "quickstart"]
          },
          {
            "group": "Usage",
            "pages": [
              "usage/modes",
              "usage/commands",
              "usage/navigation",
              "usage/editing",
              "usage/file-management",
              "usage/search",
              "usage/tabs"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "configuration/vimrc",
              "configuration/syntax-highlighting",
              "configuration/options"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/keybindings",
              "reference/ex-commands",
              "reference/file-explorer",
              "reference/cli-arguments"
            ]
          },
          {
            "group": "Development",
            "pages": [
              "development/custom-syntax",
              "development/contributing"
            ]
          }
        ]
      }
    ]
  }
}
